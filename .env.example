# Anthropic Claude API (회사 내부 게이트웨이 사용)
# API 키: 회사 내부 포털에서 발급
ANTHROPIC_API_KEY=your-company-api-key-here
ANTHROPIC_BASE_URL=https://internal-apigw-kr.hmg-corp.io/hchat-in/api/v3

# Project API Key 사용 시 입력 (Personal API Key면 비워두세요)
ANTHROPIC_PROJECT_ID=

# Gmail (뉴스레터 발송 계정)
GMAIL_USER=your-email@gmail.com

# Gmail 앱 비밀번호 (Google 계정 비밀번호 아님!)
# 설정 방법:
#   1. Google 계정 > 보안 > 2단계 인증 활성화
#   2. Google 계정 > 보안 > 2단계 인증 > 앱 비밀번호
#   3. "Newsletter CLI" 이름으로 앱 비밀번호 생성
#   4. 표시된 16자리 복사 (공백 제거 또는 그대로)
GMAIL_APP_PASSWORD=your-16-char-app-password-here
