# Anthropic API
ANTHROPIC_API_KEY=your_api_key_here

# Optional: override API endpoint (default: https://api.anthropic.com)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: custom project header (for internal gateways)
# ANTHROPIC_PROJECT_ID=

# Gmail SMTP (App Password required — NOT your Google account password)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
